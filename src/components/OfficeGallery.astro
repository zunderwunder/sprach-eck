---
import { Image } from 'astro:assets';

const officeImages = [
  {
    src: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&q=80',
    alt: 'Helle, moderne Praxisräume mit historischen Elementen'
  },
  {
    src: 'https://images.unsplash.com/photo-1600585154526-990dced4db0d?auto=format&fit=crop&w=1200&q=80',
    alt: 'Gemütlicher Therapieraum mit natürlichem Licht'
  },
  {
    src: 'https://images.unsplash.com/photo-1531835551805-16d864c8d311?auto=format&fit=crop&w=1200&q=80',
    alt: 'Historische Gebäudefassade mit Bäumen'
  },
  {
    src: 'https://images.unsplash.com/photo-1449247709967-d4461a6a6103?auto=format&fit=crop&w=1200&q=80',
    alt: 'Einladender Eingangsbereich mit Altbau-Charme'
  }
];
---

<div class="gallery-container">
  <div class="gallery-grid">
    {officeImages.map((image, index) => (
      <div class={`gallery-item item-${index + 1}`}>
        <img
          src={image.src}
          alt={image.alt}
          class="w-full h-full object-cover rounded-lg"
          width="600"
          height="600"
        />
      </div>
    ))}
  </div>
</div>

<style>
  .gallery-container {
    width: 100%;
    max-width: 1000px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    aspect-ratio: 1;
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 1;
    opacity: 0;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .item-1 {
    animation: fadeLoop 8s infinite 0s;
  }
  .item-2 {
    animation: fadeLoop 8s infinite 2s;
  }
  .item-3 {
    animation: fadeLoop 8s infinite 4s;
  }
  .item-4 {
    animation: fadeLoop 8s infinite 6s;
  }

  @keyframes fadeLoop {
    0%, 100% { opacity: 0; }
    3%, 22% { opacity: 1; }
    25% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-item {
      animation: none;
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .gallery-grid {
      gap: 0.5rem;
    }
  }
</style>
