---
import PrimaryButton from './ui/PrimaryButton.astro';
import SecondaryButton from './ui/SecondaryButton.astro';

const letters = [
  { char: 'S', x: 15, y: 25 },
  { char: 'P', x: 75, y: 15 },
  { char: 'R', x: 45, y: 65 },
  { char: 'A', x: 85, y: 45 },
  { char: 'C', x: 25, y: 75 },
  { char: 'H', x: 65, y: 35 },
  { char: 'E', x: 35, y: 85 },
  { char: 'C', x: 55, y: 55 },
  { char: 'K', x: 80, y: 70 }
];
---

<section 
  class="min-h-[95vh] flex items-center relative overflow-hidden bg-gradient-to-br from-white to-blue-50"
  x-data="{ 
    text: 'Sprache.',
    texts: ['Sprache.', 'Verstehen.', 'Begleiten.', 'Vertrauen.', 'Wachsen.'],
    currentIndex: 0,
    init() {
      this.startTypewriter();
    },
    async startTypewriter() {
      while (true) {
        await this.typeText(this.texts[this.currentIndex]);
        await this.wait(2000);
        await this.eraseText();
        this.currentIndex = (this.currentIndex + 1) % this.texts.length;
        await this.wait(200);
      }
    },
    async typeText(target) {
      this.text = '';
      for (let i = 0; i <= target.length; i++) {
        this.text = target.substring(0, i);
        await this.wait(40);
      }
    },
    async eraseText() {
      while (this.text.length > 0) {
        this.text = this.text.substring(0, this.text.length - 1);
        await this.wait(30);
      }
    },
    wait(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }
  }">
  
  <!-- Background Animation -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="floating-letters">
      {letters.map((letter) => (
        <span 
          class="floating-letter absolute text-primary/5 text-8xl font-bold pointer-events-none"
          style={`left: ${letter.x}%; top: ${letter.y}%;`}>
          {letter.char}
        </span>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <!-- Content Column -->
      <div class="lg:col-span-7 space-y-8">
        <div class="space-y-0">
          <div class="text-4xl md:text-5xl lg:text-6xl font-black text-dark font-primary leading-[1.1]">
            <div class="mb-2">Logopädie heißt</div>
            <div class="text-primary min-h-[1.1em] flex items-center">
              <span x-text="text"></span><span class="animate-pulse">|</span>
            </div>
          </div>
        </div>

        <p class="text-lg md:text-xl text-dark/70 leading-relaxed">
          Als Wahllogopädin in Baden begleite ich Kinder, Jugendliche und Erwachsene auf ihrem individuellen Weg zur Sprache – mit Expertise, Herz und einer Prise Spielfreude.
        </p>

        <div class="flex flex-wrap gap-4">
          <PrimaryButton href="/termin">
            Termin vereinbaren
          </PrimaryButton>
          <SecondaryButton 
            href="#about"
            @click="$event.preventDefault(); document.querySelector('#about').scrollIntoView({ behavior: 'smooth' })">
            Mehr erfahren
          </SecondaryButton>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
@keyframes float {
  0%, 100% {
    transform: translate(0, 0) rotate(0deg);
  }
  50% {
    transform: translate(0, -20px) rotate(5deg);
  }
}

.floating-letter {
  animation: float 4s ease-in-out infinite;
  animation-delay: calc(var(--index, 0) * -1.2s);
}

@media (prefers-reduced-motion: reduce) {
  .floating-letter {
    animation: none;
    transform: none;
  }
}
</style>