---
interface Props {
  href: string;
  class?: string;
}

const { href, class: className = "" } = Astro.props;
---

<a 
  {href}
  class={`text-sm text-dark/70 hover:text-dark transition-colors relative after:absolute after:left-0 after:bottom-[-4px] after:w-full after:h-0.5 after:bg-accent after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left ${className}`}
  x-data
  @click.prevent="document.querySelector($el.getAttribute('href')).scrollIntoView({ behavior: 'smooth' })">
  <slot />
</a>