---
import ContactForm from './ui/ContactForm.astro';
import { Image } from 'astro:assets';

const location = {
  image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80',
  address: 'Kaiser Franz Joseph-Ring 36',
  postal: '2500 Baden',
  phone: '+43 660 9027092',
  email: 'kontakt@sprach-eck.at'
};
---

<section id="contact" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold font-primary text-dark mb-4">
        Haben Sie weitere Fragen?
      </h2>
      <p class="text-lg text-dark/70 font-secondary">
        Ich bin natürlich für Sie da und freue mich auf Ihre Nachricht!
      </p>
    </div>

    <div class="grid md:grid-cols-5 gap-8">
      <!-- Location -->
      <div class="md:col-span-2 flex flex-col items-center md:items-start">
        <div class="flex flex-col w-full max-w-[300px]">
          <Image
            src={location.image}
            alt="Praxis Baden"
            width={300}
            height={200}
            class="w-[300px] h-[200px] object-cover rounded-lg"
          />
          <div class="space-y-2 mt-4">
            <h3 class="text-xl font-semibold font-primary text-dark">
              Praxis Baden
            </h3>
            <div class="space-y-2 text-base text-dark/70">
              <p>{location.address}, {location.postal}</p>
              <p>
                <a 
                  href={`tel:${location.phone.replace(/\s/g, '')}`}
                  class="hover:text-dark transition-colors relative after:absolute after:left-0 after:bottom-[-4px] after:w-full after:h-0.5 after:bg-accent after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left">
                  {location.phone}
                </a>
              </p>
              <p>
                <a 
                  href={`mailto:${location.email}`}
                  class="hover:text-dark transition-colors relative after:absolute after:left-0 after:bottom-[-4px] after:w-full after:h-0.5 after:bg-accent after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left">
                  {location.email}
                </a>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="md:col-span-3 bg-gray-50 rounded-2xl p-8">
        <ContactForm />
      </div>
    </div>
  </div>
</section>