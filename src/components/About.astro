---
import FeatureCard from './ui/FeatureCard.astro';

const features = [
  {
    title: 'Fokus auf frühe Sprachentwicklung',
    description: 'Frühzeitige Förderung für optimale Entwicklungschancen.',
    icon: 'sprout'
  },
  {
    title: 'Spezialisierung Mutismus, Stottern & Autismus',
    description: 'Expertise in der Begleitung von Kindern mit Autismus und Stottersymptomatik.',
    icon: 'circle'
  },
  {
    title: 'Ganzheitlicher Therapieansatz',
    description: 'Behandlung unter Berücksichtigung aller Lebensbereiche.',
    icon: 'heart'
  }
];
---

<section id="about" class="py-20 bg-white"
  x-data="{ 
    isVisible: false,
    init() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            this.isVisible = true;
          }
        });
      }, {
        threshold: 0.2
      });

      observer.observe(this.$refs.content);
    }
  }">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start" x-ref="content">
      <!-- Image Column -->
      <div 
        class="relative max-w-md mx-auto md:mx-0 transition-all duration-700 ease-out"
        x-bind:class="isVisible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'"
      >
        <div class="relative">
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/images/Viki-Portrait.webp"
              alt="Portrait von Viki"
              class="w-full h-full object-cover object-center"
              width="400"
              height="600"
            />
          </div>
        </div>
      </div>

      <!-- Content Column -->
      <div 
        class="space-y-8 transition-all duration-700 ease-out"
        x-bind:class="isVisible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'"
        style="transition-delay: 200ms"
      >
        <div class="space-y-4">
          <h2 class="text-3xl md:text-4xl font-bold font-primary text-dark">
            Willkommen im Sprach Eck!
          </h2>
          <p class="text-lg text-dark/70 leading-relaxed">
            In meiner logopädischen Praxis verbinde ich fachliche Expertise mit einem herzlichen, individuellen Ansatz. Ich glaube daran, dass jedes Kind seinen eigenen Weg zur Sprache findet – und begleite Familien dabei, diesen Weg mit Freude zu gehen.
          </p>
        </div>

        <div class="grid gap-6">
          {features.map((feature) => <FeatureCard {...feature} />)}
        </div>
      </div>
    </div>
  </div>
</section>
