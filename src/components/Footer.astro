---
import Logo from './Logo.astro';
import NavLink from './ui/NavLink.astro';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: "Über mich", href: "#about" },
  { label: "Leistungen", href: "#services" },
  { label: "Ablauf", href: "#process" },
  { label: "Preise", href: "#pricing" },
  { label: "Kontakt", href: "#contact" }
];
---

<footer class="py-12 bg-white border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <!-- Logo and Description -->
      <div class="md:col-span-5">
        <Logo class="h-8 w-auto text-dark" />
        <p class="mt-4 text-sm text-dark/70 leading-relaxed">
          Sprach Eck – Logopädie für Kinder und Erwachsene in Baden.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="md:col-span-3">
        <h3 class="font-semibold mb-4 text-dark font-primary">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map(({ label, href }) => (
            <li>
              <NavLink {href}>
                {label}
              </NavLink>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-4">
        <h3 class="font-semibold mb-4 text-dark font-primary">Kontakt</h3>
        <div class="space-y-2 text-sm text-dark/70">
          <p>Kaiser Franz Joseph-Ring 36</p>
          <p>2500 Baden</p>
          <p>
            <a 
              href="tel:+436609027092"
              class="hover:text-dark transition-colors relative after:absolute after:left-0 after:bottom-[-4px] after:w-full after:h-0.5 after:bg-accent after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left">
              +43 660 9027092
            </a>
          </p>
          <p>
            <a 
              href="mailto:kontakt@sprach-eck.at"
              class="hover:text-dark transition-colors relative after:absolute after:left-0 after:bottom-[-4px] after:w-full after:h-0.5 after:bg-accent after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left">
              kontakt@sprach-eck.at
            </a>
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Footer -->
    <div class="mt-12 pt-8 border-t border-gray-100">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-dark/60">
        <div class="w-full text-center">
          © {currentYear} Sprach Eck. Alle Rechte vorbehalten. Website erstellt von <a href="https://zunderwunder.at" class="hover:text-dark transition-colors relative after:absolute after:left-0 after:bottom-[-2px] after:w-full after:h-0.5 after:bg-accent after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left" target="_blank" rel="noopener noreferrer">Zunderwunder</a>.
        </div>
        <div class="flex items-center gap-4">
          <a href="/impressum" class="hover:text-dark transition-colors relative after:absolute after:left-0 after:bottom-[-2px] after:w-full after:h-0.5 after:bg-accent after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left">Impressum</a>
          <span>|</span>
          <a href="/datenschutz" class="hover:text-dark transition-colors relative after:absolute after:left-0 after:bottom-[-2px] after:w-full after:h-0.5 after:bg-accent after:scale-x-0 after:origin-right after:transition-transform hover:after:scale-x-100 hover:after:origin-left">Datenschutzerklärung</a>
        </div>
      </div>
    </div>
  </div>
</footer>