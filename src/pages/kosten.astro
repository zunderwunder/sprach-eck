---
import Layout from '../layouts/Layout.astro';
import PrimaryButton from '../components/ui/PrimaryButton.astro';
import SecondaryButton from '../components/ui/SecondaryButton.astro';

const prices = [
  {
    title: "Erstgespräch",
    duration: "60 Minuten",
    price: "90",
    details: "Ausführliche Anamnese und Beratung",
    included: [
      "Ausführliche Befunderhebung",
      "Erste diagnostische Einschätzung",
      "Therapieplanung",
      "Kostenübernahme besprechen"
    ]
  },
  {
    title: "Einzeltherapie",
    duration: "45 Minuten",
    price: "85",
    details: "Individuelle Therapieeinheit",
    included: [
      "Therapeutische Intervention",
      "Übungsmaterial für zuhause",
      "Dokumentation",
      "Elterngespräch/Beratung"
    ],
    highlight: true
  },
  {
    title: "Diagnostik",
    duration: "90 Minuten",
    price: "130",
    details: "Umfassende Untersuchung",
    included: [
      "Standardisierte Tests",
      "Ausführliche Auswertung",
      "Schriftlicher Befund",
      "Therapieempfehlung"
    ]
  }
];

const insuranceInfo = [
  {
    title: "Krankenkasse",
    icon: "hospital",
    description: "Die Kosten werden bei ärztlicher Verordnung von den Krankenkassen übernommen."
  },
  {
    title: "Privatversicherung",
    icon: "shield-alt",
    description: "Private Zusatzversicherungen übernehmen oft einen Teil der Kosten."
  },
  {
    title: "Selbstzahler",
    icon: "wallet",
    description: "Direkte Abrechnung ohne Versicherung möglich."
  }
];
---

<Layout title="Kosten & Tarife | Sprach Eck">
    <!-- Intro Section -->
    <section class="pt-20 pb-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <h1 class="text-4xl font-bold mb-6 font-primary text-[#2D3748]">Kosten & Tarife</h1>
            <div class="prose max-w-none">
                <p class="font-['Avenir_Light'] text-lg mb-4 text-[#4A5568]">
                    Transparente Preisgestaltung und professionelle Leistungen sind mir wichtig. Die Kosten für logopädische Therapie werden in vielen Fällen von den Krankenkassen übernommen.
                </p>
            </div>
        </div>
    </section>

    <!-- Pricing Cards Section -->
    <section class="py-16 bg-gradient-to-br from-white via-[#E6EFEF]/30 to-[#f39256]/10">
        <div class="max-w-6xl mx-auto px-4">
            <h2 class="text-3xl font-bold text-center mb-16 font-primary text-[#2D3748]">Unsere Tarife</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {prices.map(price => (
                    <div 
                        class:list={[
                            "relative p-6 rounded-xl bg-white shadow-lg transform transition-all duration-300 hover:-translate-y-1",
                            price.highlight && "border-t-4 border-[#f39256]"
                        ]}
                        x-data="{ shown: false }"
                        x-intersect:enter="$el.style.opacity = 1; $el.style.transform = 'translateY(0)'"
                        x-intersect:leave="$el.style.opacity = 0; $el.style.transform = 'translateY(20px)'"
                        style="opacity: 0; transform: translateY(20px)">
                        
                        <div class="text-center mb-8">
                            <h3 class="text-xl font-bold mb-2 font-primary text-[#2D3748]">{price.title}</h3>
                            <p class="text-[#4A5568] font-['Avenir_Light']">{price.duration}</p>
                            <div class="mt-4">
                                <span class="text-3xl font-bold text-[#f39256]">€{price.price}</span>
                            </div>
                            <p class="text-sm text-[#4A5568] mt-2 font-['Avenir_Light']">{price.details}</p>
                        </div>

                        <div class="space-y-3">
                            {price.included.map(item => (
                                <div class="flex items-center">
                                    <i class="fas fa-check text-[#f39256] mr-3"></i>
                                    <span class="text-[#4A5568] font-['Avenir_Light']">{item}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Insurance Info Section -->
    <section class="py-16">
        <div class="max-w-6xl mx-auto px-4">
            <h2 class="text-3xl font-bold text-center mb-16 font-primary text-[#2D3748]">Kostenübernahme</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {insuranceInfo.map(info => (
                    <div 
                        class="p-6 rounded-xl bg-white shadow-lg"
                        x-data="{ shown: false }"
                        x-intersect:enter="$el.style.opacity = 1; $el.style.transform = 'translateY(0)'"
                        x-intersect:leave="$el.style.opacity = 0; $el.style.transform = 'translateY(20px)'"
                        style="opacity: 0; transform: translateY(20px)">
                        
                        <div class="flex items-center mb-4">
                            <div class="w-12 h-12 rounded-full bg-[#f39256]/10 flex items-center justify-center mr-4">
                                <i class={`fas fa-${info.icon} text-[#f39256] text-xl`}></i>
                            </div>
                            <h3 class="text-xl font-bold font-primary text-[#2D3748]">{info.title}</h3>
                        </div>
                        
                        <p class="text-[#4A5568] font-['Avenir_Light']">{info.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-gradient-to-br from-white via-[#E6EFEF]/30 to-[#f39256]/10">
        <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-8 font-primary text-[#2D3748]">Noch Fragen?</h2>
            <p class="font-['Avenir_Light'] text-lg text-[#4A5568] mb-8">
                Ich berate Sie gerne zu allen Fragen rund um die Kostenübernahme und Therapiemöglichkeiten.
            </p>
            <div class="flex justify-center gap-4">
                <PrimaryButton href="/kontakt">Kontakt aufnehmen</PrimaryButton>
                <SecondaryButton href="/therapie">Therapieangebot</SecondaryButton>
            </div>
        </div>
    </section>
</Layout>

<style>
.transform {
    transition: all 0.3s ease-out;
}
</style> 