---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Preise | Sprach Eck">
  <section class="container mx-auto p-6">
    <h1 class="font-quicksand text-4xl font-bold mb-3 text-center">🛡️ Professional Care & Hosting</h1>
    <p class="font-['Avenir_Light'] text-center text-xl mb-12">Rundum-Betreuung für Ihre Website</p>
    
    <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
      <!-- Essential Care -->
      <div class="bg-white rounded-2xl shadow-lg p-6 hover:shadow-xl transition-shadow">
        <div class="text-center mb-6">
          <h2 class="font-quicksand text-2xl font-bold mb-2">🌱 Essential Care</h2>
          <p class="text-3xl font-bold text-[#006B67] mb-2">39 €<span class="text-lg"> / Monat</span></p>
          <p class="font-['Avenir_Light'] text-sm">Jahrespaket: 390 €</p>
          <p class="text-sm text-green-600">(2 Monate geschenkt - 78 € Ersparnis sichern)</p>
          <p class="text-sm mt-2 text-gray-600">Für ca. 1,10 €/Tag</p>
          <p class="text-xs text-gray-500">günstiger als Marken-Kaugummis trotz Inflation</p>
        </div>

        <ul class="space-y-3 mb-6 font-['Avenir_Light']">
          <li class="flex items-start">
            <span class="mr-2">🛡️</span>
            <span> Premium Hosting & SSL</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">💾</span>
            <span> Tägliche Backups</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">🔄</span>
            <span> Security-Updates</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">📱</span>
            <span> Performance-Monitoring</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">📝</span>
            <span> 1x Content-Quick-Update/Monat (à 15min)</span>
          </li>
          <li class="ml-6 text-sm text-gray-600">• Text- & Bildänderungen</li>
          <li class="ml-6 text-sm text-gray-600">• Kleine Layout-Anpassungen</li>
          <li class="ml-6 text-sm text-gray-600">• Umfangreichere Änderungen: 110€/h</li>
          <li class="flex items-start">
            <span class="mr-2">⏱️</span>
            <span> 48h Support-Response</span>
          </li>
        </ul>

        <p class="text-center text-sm text-gray-600 mt-4">Perfekt für: Selbstständige & kleine Praxen</p>
      </div>

      <!-- Business Care (Recommended) -->
      <div class="bg-white rounded-2xl shadow-lg p-6 hover:shadow-xl transition-shadow transform scale-105 border-2 border-[#006B67]">
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
          <span class="bg-[#006B67] text-white px-4 py-1 rounded-full text-sm">Empfohlen</span>
        </div>
        <div class="text-center mb-6">
          <h2 class="font-quicksand text-2xl font-bold mb-2">🚀 Business Care</h2>
          <p class="text-3xl font-bold text-[#006B67] mb-2">69 €<span class="text-lg"> / Monat</span></p>
          <p class="font-['Avenir_Light'] text-sm">Jahrespaket: 690 €</p>
          <p class="text-sm text-green-600">(2 Monate geschenkt - 138 € Ersparnis sichern)</p>
          <p class="text-sm mt-2 text-gray-600">Für ca. 1,90 €/Tag</p>
          <p class="text-xs text-gray-500">günstiger als ein Coffee-to-Go</p>
        </div>

        <ul class="space-y-3 mb-6 font-['Avenir_Light']">
          <li class="flex items-start">
            <span class="mr-2">✨</span>
            <span> Alle Essential Care Features plus:</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">📝</span>
            <span> 2x Content-Quick-Updates/Monat (à 15min)</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">🎯</span>
            <span> Halbjährliches Growth-Review (45min)</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">⚡</span>
            <span> 24h Support-Response</span>
          </li>
        </ul>

        <p class="text-center text-sm text-gray-600 mt-4">Perfekt für: Wachsende Praxen & etablierte Unternehmen</p>
      </div>

      <!-- Premium Care -->
      <div class="bg-white rounded-2xl shadow-lg p-6 hover:shadow-xl transition-shadow">
        <div class="text-center mb-6">
          <h2 class="font-quicksand text-2xl font-bold mb-2">💫 Premium Care</h2>
          <p class="text-3xl font-bold text-[#006B67] mb-2">99 €<span class="text-lg"> / Monat</span></p>
          <p class="font-['Avenir_Light'] text-sm">Jahrespaket: 990 €</p>
          <p class="text-sm text-green-600">(2 Monate geschenkt - 198 € Ersparnis sichern)</p>
          <p class="text-sm mt-2 text-gray-600">Für ca. 2,70 €/Tag</p>
          <p class="text-xs text-gray-500">günstiger als ein Starbucks White Chocolate Mocha</p>
        </div>

        <ul class="space-y-3 mb-6 font-['Avenir_Light']">
          <li class="flex items-start">
            <span class="mr-2">✨</span>
            <span> Alle Business Care Features plus:</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">📝</span>
            <span> 4x Content-Quick-Updates/Monat (à 15min)</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">🎯</span>
            <span> Quartalsweises Growth-Review (60min)</span>
          </li>
          <li class="flex items-start">
            <span class="mr-2">⚡</span>
            <span> 12h Support-Response</span>
          </li>
        </ul>

        <p class="text-center text-sm text-gray-600 mt-4">Perfekt für: Größere Unternehmen & Organisationen</p>
      </div>
    </div>
  </section>
</Layout> 