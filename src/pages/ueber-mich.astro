---
import Layout from '../layouts/Layout.astro';
import PrimaryButton from '../components/ui/PrimaryButton.astro';
import SecondaryButton from '../components/ui/SecondaryButton.astro';

const expertise = [
  {
    year: 2015,
    title: "FH Campus Wien",
    subtitle: "Bachelor Logopädie",
    details: "Fundierte Ausbildung in allen Bereichen der Sprachtherapie",
    highlight: true
  },
  {
    year: 2016,
    title: "Berufseinstieg",
    subtitle: "Erste Praxiserfahrungen",
    details: "Intensive Arbeit mit verschiedenen Störungsbildern"
  },
  {
    year: 2018,
    title: "Spezialisierung Autismus",
    subtitle: "Zertifizierte Weiterbildung",
    details: "Fokus auf komplexe Entwicklungsstörungen",
    highlight: true
  },
  {
    year: 2020,
    title: "Eigene Praxis",
    subtitle: "Sprach Eck Baden",
    details: "Gründung der eigenen logopädischen Praxis",
    highlight: true
  }
];

const specializations = [
  {
    area: "Autismus",
    level: 95,
    icon: "puzzle-piece",
    description: "Spezialisiert auf Autismus-Spektrum-Störungen"
  },
  {
    area: "Stottern",
    level: 90,
    icon: "wave-square",
    description: "Therapie von Redeflussstörungen"
  },
  {
    area: "Kindersprache",
    level: 98,
    icon: "child",
    description: "Entwicklungsverzögerungen & -störungen"
  }
];
---

<Layout title="Über Mich | Sprach Eck">
    <!-- Intro Section -->
    <section class="pt-20 pb-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <div class="flex flex-col md:flex-row items-center gap-12">
                <!-- Image Container -->
                <div class="w-full md:w-1/3 relative">
                    <div class="aspect-square rounded-2xl overflow-hidden shadow-lg">
                        <img 
                            src="https://images.unsplash.com/photo-1544717302-de2939b7ef71?auto=format&fit=crop&w=600&h=600&q=100"
                            alt="Logopädin im Sprach Eck Baden" 
                            class="w-full h-full object-cover object-center"
                            x-data
                            x-intersect:enter="$el.style.opacity = 1; $el.style.transform = 'scale(1)'"
                            x-intersect:leave="$el.style.opacity = 0; $el.style.transform = 'scale(0.95)'"
                            style="opacity: 0; transform: scale(0.95); transition: all 0.5s ease-out"
                        />
                    </div>
                    <div class="absolute -z-10 -bottom-4 -right-4 w-full h-full rounded-2xl bg-[#f39256]/10"></div>
                    <div class="absolute -z-20 -top-4 -left-4 w-full h-full rounded-2xl bg-[#E6EFEF]/30"></div>
                </div>

                <!-- Text Content -->
                <div class="w-full md:w-2/3">
                    <h1 class="text-4xl font-bold mb-6 font-primary text-[#2D3748]">Über mich</h1>
                    <div class="prose max-w-none">
                        <p class="font-['Avenir_Light'] text-lg mb-4 text-[#4A5568]">
                            Herzlich willkommen im Sprach Eck Baden! Als diplomierte Logopädin biete ich professionelle logopädische Therapie für Kinder, Jugendliche und Erwachsene an.
                        </p>
                        <p class="font-['Avenir_Light'] text-lg mb-8 text-[#4A5568]">
                            In meiner Praxis steht der Mensch im Mittelpunkt. Jede Therapie wird individuell auf die Bedürfnisse meiner Patienten abgestimmt.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline Section -->
<section class="py-16 bg-gradient-to-br from-white via-[#E6EFEF]/30 to-[#f39256]/10">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-16 font-primary text-[#2D3748]">Mein Werdegang</h2>
        
        <div class="relative max-w-5xl mx-auto" x-data="{ /* ... existing x-data ... */ }">
            
            <!-- Center Timeline Line -->
            <div class="absolute left-1/2 top-0 bottom-0 w-0.5 bg-gray-100 -translate-x-1/2">
                <div 
                    class="absolute top-0 left-0 w-full bg-[#f39256] transition-all duration-1000 ease-in-out"
                    style="height: 0%;"
                    x-ref="progress"
                    x-effect="$refs.progress.style.height = (Math.max(...Array.from(activeSteps)) + 1) * 25 + '%'">
                </div>
            </div>

            <!-- Timeline Steps -->
            <div class="relative space-y-24">
                {expertise.map((item, i) => (
                    <div 
                        class="relative grid grid-cols-[1fr,auto,1fr] gap-8"
                        data-step={i}
                        x-bind:class={`activeSteps.has(${i}) ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4'`}
                    >
                        <!-- Content Card -->
                        <div class={`transition-all duration-700 ${i % 2 === 0 ? 'col-start-1 pr-8' : 'col-start-3 pl-8'}`}>
                            <div 
                                class={`relative p-6 rounded-xl bg-white shadow-lg ${item.highlight ? 'border-l-4 border-[#f39256]' : ''}`}
                                x-bind:class={`activeSteps.has(${i}) ? 'opacity-100 ${i % 2 === 0 ? 'translate-x-0' : '-translate-x-0'}' : 'opacity-0 ${i % 2 === 0 ? '-translate-x-8' : 'translate-x-8'}'`}
                            >
                                <div class="inline-block px-3 py-1 rounded-full bg-[#f39256]/10 mb-3">
                                    <span class="text-[#f39256] font-bold font-primary">{item.year}</span>
                                </div>
                                
                                <h3 class="text-xl font-bold mb-2 font-primary text-[#2D3748]">{item.title}</h3>
                                <p class="text-[#4A5568] font-['Avenir_Light'] mb-3">{item.subtitle}</p>
                                
                                <div 
                                    class="h-0.5 bg-[#f39256]/10 my-3"
                                    x-data
                                    x-intersect:enter="$el.style.width = '100%'"
                                    x-intersect:leave="$el.style.width = '0%'"
                                    style="width: 0%; transition: width 1s ease-out">
                                </div>
                                
                                <p class="text-sm text-[#4A5568] font-['Avenir_Light']">{item.details}</p>
                            </div>
                        </div>

                        <!-- Timeline Dot -->
                        <div class="col-start-2 self-center"> <!-- Changed to self-center -->
                            <div 
                                class="w-4 h-4 rounded-full border-2 transition-colors duration-700 z-10 bg-white"
                                x-bind:class={`activeSteps.has(${i}) ? 'border-[#f39256] bg-[#f39256]' : 'border-gray-300 bg-white'`}>
                            </div>
                        </div>

                        <!-- Empty Column for Alternating Layout -->
                        <div class={`${i % 2 === 0 ? 'col-start-3' : 'col-start-1'}`}></div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

    <!-- Expertise Section -->
<section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-16 font-primary text-[#2D3748]">Meine Expertise</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {specializations.map(spec => (
                <div 
                    class="relative p-6 rounded-xl bg-white shadow-lg transform transition-all duration-300 hover:-translate-y-1"
                    x-data="{ hover: false, inView: false }"
                    x-intersect:enter="inView = true"
                    x-intersect:leave="inView = false"
                    @mouseenter="hover = true"
                    @mouseleave="hover = false"
                >
                    <!-- Icon -->
                    <div class="absolute -top-6 left-6">
                        <div class="w-12 h-12 rounded-full bg-[#f39256] text-white flex items-center justify-center shadow-lg">
                            <i class={`fas fa-${spec.icon} text-xl`}></i>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="mt-8">
                        <h3 class="text-xl font-bold font-primary text-[#2D3748] mb-4">{spec.area}</h3>
                        
                        <!-- Progress Bar Container -->
                        <div class="relative h-2 bg-gray-200 rounded-full overflow-hidden mb-2">
                            <!-- Progress Bar Fill -->
                            <div 
                                class="absolute top-0 left-0 h-full bg-[#f39256] rounded-full transition-all duration-1500 ease-out"
                                x-ref="progress"
                                x-bind:style="inView ? `width: ${spec.level}%` : 'width: 0%'"
                            ></div>
                        </div>

                        <!-- Percentage Display -->
                        <div 
                            class="text-sm font-bold text-[#f39256] mb-4"
                            x-data
                            x-intersect:enter="$el.style.opacity = 1; $el.style.transform = 'translateY(0)'"
                            x-intersect:leave="$el.style.opacity = 0; $el.style.transform = 'translateY(10px)'"
                            style="opacity: 0; transform: translateY(10px); transition: all 0.5s ease-out"
                        >
                            <span x-text="`${spec.level}%`"></span>
                        </div>

                        <p class="text-[#4A5568] font-['Avenir_Light']">{spec.description}</p>
                    </div>

                    <!-- Hover Effect -->
                    <div 
                        class="absolute inset-0 bg-gradient-to-br from-[#f39256]/10 to-transparent rounded-xl transition-opacity duration-300"
                        x-bind:class="hover ? 'opacity-100' : 'opacity-0'">
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

    <!-- CTA Section -->
    <section class="py-16 bg-gradient-to-br from-white via-[#E6EFEF]/30 to-[#f39256]/10">
        <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-8 font-primary text-[#2D3748]">Haben Sie Fragen?</h2>
            <p class="font-['Avenir_Light'] text-lg text-[#4A5568] mb-8">
                Ich berate Sie gerne persönlich und beantworte alle Ihre Fragen zur logopädischen Therapie.
            </p>
            <div class="flex justify-center gap-4">
                <PrimaryButton href="/kontakt">Kontakt aufnehmen</PrimaryButton>
                <SecondaryButton href="/therapie">Therapieangebot</SecondaryButton>
            </div>
        </div>
    </section>
</Layout>

<style>
.transform {
    transition: all 0.3s ease-out;
}

.path-line {
    opacity: 0.3;
}
</style> 