---
import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/ui/FeatureCard.astro';
import Icon from '../components/ui/Icon.astro';
import PrimaryButton from '../components/ui/PrimaryButton.astro';

const expertise = [
  {
    title: 'Kindersprache & Entwicklung',
    description: 'Mein Herz schlägt für die frühe Sprachentwicklung. Mit viel Einfühlungsvermögen begleite ich Kinder auf ihrem individuellen Weg.',
    icon: 'sprout'
  },
  {
    title: 'Ganzheitlicher Ansatz',
    description: 'Durch meine Erfahrung in der Praxis Sprecherei und zahlreiche Fortbildungen biete ich eine umfassende therapeutische Betreuung.',
    icon: 'circle'
  },
  {
    title: 'Vorträge & Beratung',
    description: 'Regelmäßige Infoabende und Vorträge im Kindergarten-Setting sowie am Biofeedback Kongress zeigen mein Engagement für Aufklärung.',
    icon: 'star'
  }
];

const education = [
  {
    period: '2017 - 2020',
    title: 'Bachelor-Studium Logopädie',
    description: 'FH Wiener Neustadt'
  },
  {
    period: '2020 - 2022',
    title: 'Praxis Sprecherei',
    description: 'Intensive Expertise-Entwicklung im Team und Spezialisierung auf Kindersprache'
  },
  {
    period: 'seit März 2022',
    title: 'Sprach Eck',
    description: 'Eigene logopädische Praxis in Baden'
  }
];

const specializations = [
  'Interaktionelle Therapie bei Sprachentwicklungsstörungen',
  'Komm!ASS® für Autismus Spektrum Störungen',
  'Myofunktionelle Therapie',
  'Selektiver Mutismus',
  'Neurofunktionstherapie (NF!T®)'
];

const milestones = [
  {
    title: 'Erste Schritte zur Logopädie',
    description: 'Während meiner Schulzeit am humanistischen Gymnasium entdeckte ich durch 5-jährige Theatererfahrung meine Leidenschaft für Sprache. Als Rettungssanitäterin entwickelte ich zusätzlich großes medizinisches Interesse.',
    year: '2013 - 2017'
  },
  {
    title: 'Bachelor-Studium Logopädie',
    description: 'Fundierte Ausbildung an der FH Wiener Neustadt mit Fokus auf evidenzbasierte Therapieansätze und praktische Erfahrung.',
    year: '2017 - 2020'
  },
  {
    title: 'Praxis Sprecherei',
    description: 'Intensive Expertise-Entwicklung im Team, Spezialisierung auf Kindersprache und zahlreiche Fortbildungen in interaktioneller Therapie.',
    year: '2020 - 2022'
  },
  {
    title: 'Gründung Sprach Eck',
    description: 'Start meiner eigenen logopädischen Praxis in Baden. Regelmäßige Vorträge und Infoabende für Eltern und Fachpersonal.',
    year: 'seit März 2022'
  }
];
---

<Layout title="Über mich - Sprach Eck">
  <main class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Hero Section mit Fade-In Animation -->
      <div class="grid md:grid-cols-2 gap-12 items-start"
        x-data="{ show: false }"
        x-intersect="show = true"
        x-bind:class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'"
        class="transition-all duration-1000">
        <div class="relative max-w-md mx-auto md:mx-0">
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/images/Viki-Portrait.webp"
              alt="Portrait von Viki"
              class="w-full h-full object-cover object-center"
              width="400"
              height="600"
            />
          </div>
        </div>

        <div class="space-y-6">
          <h1 class="text-4xl font-bold font-primary text-dark">
            Hi, ich bin Viki!
          </h1>
          <div class="space-y-4 text-lg text-dark/70">
            <p>
              Meine Begeisterung für Sprache entdeckte ich bereits während meiner Schulzeit am humanistischen Gymnasium, wo ich 5 Jahre lang Theatererfahrung sammeln durfte.
            </p>
            <p>
              Die Kombination aus meinem medizinischen Interesse als Rettungssanitäterin und der Freude an der Begleitung von Familien durch mehrjährige Kinderbetreuung führte mich zur Logopädie.
            </p>
            <p>
              Heute begleite ich Kinder, Jugendliche und Erwachsene mit verschiedenen logopädischen Anliegen und nehme mir gerne Zeit, zu allen Themen transparent zu beraten.
            </p>
          </div>
          <div class="pt-4">
            <PrimaryButton href="/kontakt">
              Kontakt aufnehmen
            </PrimaryButton>
          </div>
        </div>
      </div>

      <!-- Expertise Cards mit gestaffeltem Fade-In -->
      <div class="mt-24"
        x-data="{ show: false }"
        x-intersect="show = true">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl md:text-4xl font-bold font-primary text-dark mb-4">
            Meine Expertise
          </h2>
          <p class="text-lg text-dark/70 font-secondary">
            Spezialisiert auf Kindersprachentwicklung und ganzheitliche Betreuung von Familien.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {expertise.map((item, index) => (
            <div
              x-bind:class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'"
              class="transition-all duration-700"
              style={`transition-delay: ${index * 200}ms`}>
              <FeatureCard {...item} />
            </div>
          ))}
        </div>
      </div>

      <!-- Milestones Timeline Section -->
      <section class="py-16 md:py-24 bg-white"
        x-data="{ 
          activeSteps: new Set(),
          init() {
            const observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                const stepIndex = parseInt(entry.target.dataset.step);
                if (entry.isIntersecting) {
                  this.activeSteps.add(stepIndex);
                } else {
                  if (entry.boundingClientRect.top > 0) {
                    this.activeSteps.delete(stepIndex);
                  }
                }
              });
            }, {
              threshold: 0.5,
              rootMargin: '-10% 0px -10% 0px'
            });

            document.querySelectorAll('[data-step]').forEach(step => {
              observer.observe(step);
            });
          }
        }">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
          <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-bold font-primary text-dark mb-4">
              Mein Weg zur Logopädie
            </h2>
            <p class="text-lg text-dark/70 font-secondary">
              Eine Reise geprägt von Leidenschaft für Sprache, medizinischem Interesse und dem Wunsch, Menschen auf ihrem Weg zu begleiten.
            </p>
          </div>

          <div class="relative max-w-3xl mx-auto">
            <!-- Timeline Line -->
            <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-gray-100">
              <div 
                class="absolute top-0 left-0 w-full bg-accent transition-all duration-1000 ease-in-out"
                style="height: 0%;"
                x-ref="progress"
                x-effect="$refs.progress.style.height = (Math.max(...Array.from(activeSteps)) + 1) * 25 + '%'">
              </div>
            </div>

            <!-- Timeline Steps -->
            <div class="space-y-12">
              {milestones.map((milestone, i) => (
                <div 
                  class="relative pl-24 flex items-start transition-all duration-700 ease-out"
                  data-step={i}
                  x-bind:class={`activeSteps.has(${i}) ? 'opacity-100 translate-x-0' : 'opacity-0 translate-x-4'`}
                >
                  <!-- Timeline Dot -->
                  <div 
                    class="absolute left-7 top-2.5 w-2 h-2 rounded-full border-2 transition-colors duration-700"
                    x-bind:class={`activeSteps.has(${i}) ? 'border-accent bg-accent' : 'border-gray-300 bg-white'`}>
                  </div>

                  <div class="flex-1 transition-all duration-700">
                    <div class="text-accent font-semibold mb-1">{milestone.year}</div>
                    <h3 class="text-xl font-semibold font-primary text-dark mb-2">
                      {milestone.title}
                    </h3>
                    <p class="text-dark/70 leading-relaxed font-secondary">
                      {milestone.description}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Specializations mit Stagger-Effect -->
      <div class="mt-24"
        x-data="{ show: false }"
        x-intersect="show = true">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl md:text-4xl font-bold font-primary text-dark mb-4">
            Schwerpunkte & Fortbildungen
          </h2>
          <p class="text-lg text-dark/70 font-secondary">
            Kontinuierliche Weiterbildung für bestmögliche therapeutische Begleitung.
          </p>
        </div>
        <div class="max-w-2xl mx-auto">
          <ul class="space-y-4">
            {specializations.map((spec, index) => (
              <li 
                class="flex gap-3 transition-all duration-500"
                x-bind:class="show ? 'opacity-100 translate-x-0' : 'opacity-0 -translate-x-8'"
                style={`transition-delay: ${index * 100}ms`}>
                <Icon name="check" class="w-5 h-5 text-primary flex-shrink-0 mt-1" />
                <span class="text-dark/70">{spec}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </main>
</Layout>
